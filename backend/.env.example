# AI API Keys
OPENAI_API_KEY=
LLAMA_CLOUD_API_KEY=

# Relational Database (PostgreSQL / SQLite)
# Defaults to sqlite:///./sql_app.db if left blank
DATABASE_URL=

# Qdrant Vector Database (Cloud / Local)
# Defaults to in-memory Qdrant client if left blank
QDRANT_URL=
QDRANT_API_KEY=

# Neo4j Graph Database (Cloud / Local)
# Defaults to in-memory graph store if left blank
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
